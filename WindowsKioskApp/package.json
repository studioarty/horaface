{
  "name": "IgrejaKioskApp",
  "version": "1.0.0",
  "description": "Kiosk Imersivo do Ponto e Painel da Igreja",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.igrejakiosk.desktop",
    "productName": "KIOSK PONTO IBAV",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "runAfterFinish": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "KIOSK PONTO IBAV",
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "allowElevation": true,
      "include": "build/installer.nsh"
    }
  },
  "author": "IBAV Developer AI",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}